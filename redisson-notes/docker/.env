# Redisson 测试环境配置
# 项目配置
PROJECT_NAME=redisson-notes
PROJECT_VERSION=3.50.0

# Redis 服务配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Redis 单机模式
REDIS_SINGLE_NAME=redisson-test-redis
REDIS_SINGLE_PORT=6379
REDIS_SINGLE_IMAGE=redis:7.2-alpine

# Redis 集群模式
REDIS_CLUSTER_NAME=redisson-test-redis-cluster
REDIS_CLUSTER_PORTS=7000,7001,7002,7003,7004,7005
REDIS_CLUSTER_IMAGE=redis:7.2-alpine

# Redis Sentinel 模式
REDIS_SENTINEL_MASTER_NAME=redisson-test-redis-sentinel-master
REDIS_SENTINEL_MASTER_PORT=6380
REDIS_SENTINEL_SLAVE1_NAME=redisson-test-redis-sentinel-slave1
REDIS_SENTINEL_SLAVE1_PORT=6381
REDIS_SENTINEL_SLAVE2_NAME=redisson-test-redis-sentinel-slave2
REDIS_SENTINEL_SLAVE2_PORT=6382
REDIS_SENTINEL1_NAME=redisson-test-redis-sentinel1
REDIS_SENTINEL1_PORT=26379
REDIS_SENTINEL2_NAME=redisson-test-redis-sentinel2
REDIS_SENTINEL2_PORT=26380
REDIS_SENTINEL3_NAME=redisson-test-redis-sentinel3
REDIS_SENTINEL3_PORT=26381
REDIS_SENTINEL_IMAGE=redis:7.2-alpine

# 网络配置
NETWORK_NAME=redisson-test-network

# 数据卷配置
REDIS_DATA_VOLUME=redisson_redis_data
REDIS_CLUSTER_DATA_VOLUME=redisson_redis_cluster_data
REDIS_SENTINEL_DATA_VOLUME=redisson_redis_sentinel_data

# 时区配置
TIMEZONE=Asia/Shanghai

# 健康检查配置
HEALTH_CHECK_INTERVAL=10s
HEALTH_CHECK_TIMEOUT=5s
HEALTH_CHECK_RETRIES=5

# 连接配置
CONNECTION_POOL_SIZE=10
CONNECTION_MIN_IDLE=5
CONNECTION_TIMEOUT=10000
IDLE_CONNECTION_TIMEOUT=10000
TIMEOUT=3000
RETRY_ATTEMPTS=3
RETRY_INTERVAL=1500
